<!-- 视图3: 知识图谱 -->
<div class="view-header">
  <h2>知识图谱</h2>
</div>

<div class="kpi-row" id="kg-kpis">
  <div class="kpi-card"><span class="kpi-value" id="kg-nodes">0</span><span class="kpi-label">节点总数</span></div>
  <div class="kpi-card"><span class="kpi-value" id="kg-links">0</span><span class="kpi-label">关系总数</span></div>
  <div class="kpi-card"><span class="kpi-value" id="kg-types">0</span><span class="kpi-label">实体类型数</span></div>
</div>

<hr>

<div class="form-group">
  <label>筛选实体类型 (留空显示全部)</label>
  <div id="kg-type-filter" class="checkbox-group"></div>
</div>

<!-- Visualization mode tabs -->
<div class="sub-tabs">
  <button class="sub-tab active" data-viz="standard">标准视图</button>
  <button class="sub-tab" data-viz="force">力导向</button>
  <button class="sub-tab" data-viz="fisheye">鱼眼视图</button>
  <button class="sub-tab" data-viz="3d">三维视图</button>
</div>

<div class="legend" id="kg-legend"></div>

<div id="kg-standard" class="chart-container" style="height:620px;"></div>
<div id="kg-force" class="chart-container" style="display:none; height:650px;"></div>
<div id="kg-fisheye" class="chart-container" style="display:none; height:650px;"></div>
<div id="kg-3d" class="chart-container" style="display:none; height:650px;"></div>

<details>
  <summary>查看所有节点详情</summary>
  <table id="kg-node-table" class="data-table">
    <thead><tr><th>ID</th><th>类型</th><th>内容</th></tr></thead>
    <tbody></tbody>
  </table>
</details>
