<!-- 视图6: 证据问答 -->
<div class="view-header">
  <h2>证据问答</h2>
</div>

<p class="caption">基于知识图谱的智能问答，答案可追溯到原文段落。</p>

<div class="qa-container">
  <div id="qa-messages"></div>

  <div class="qa-input-area">
    <textarea id="qa-input" placeholder="输入问题，系统将从知识图谱中检索证据并回答..." rows="2"></textarea>
    <button class="btn btn-primary" id="qa-submit-btn">发送</button>
  </div>
</div>
