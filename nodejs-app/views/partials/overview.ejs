<!-- 视图1: 态势总览 -->
<div class="view-header">
  <h2>态势总览</h2>
</div>

<div class="kpi-row" id="overview-kpis">
  <div class="kpi-card"><span class="kpi-value" id="kpi-chunks">0</span><span class="kpi-label">文本块数</span></div>
  <div class="kpi-card"><span class="kpi-value" id="kpi-entities">0</span><span class="kpi-label">识别实体</span></div>
  <div class="kpi-card"><span class="kpi-value" id="kpi-relations">0</span><span class="kpi-label">发现关系</span></div>
  <div class="kpi-card"><span class="kpi-value" id="kpi-persons">0</span><span class="kpi-label">识别人物</span></div>
  <div class="kpi-card"><span class="kpi-value" id="kpi-locations">0</span><span class="kpi-label">地理位置</span></div>
  <div class="kpi-card"><span class="kpi-value" id="kpi-chars">0</span><span class="kpi-label">总字符数</span></div>
</div>

<hr>

<div class="chart-row">
  <div class="chart-half">
    <h4>实体类型分布</h4>
    <div id="chart-entity-pie" class="chart-container"></div>
  </div>
  <div class="chart-half">
    <h4>关系类型分布</h4>
    <div id="chart-rel-bar" class="chart-container"></div>
  </div>
</div>

<details open>
  <summary>文档内容层级结构 (DocuBurst)</summary>
  <div id="chart-docuburst" class="chart-container"></div>
</details>

<hr>

<div class="chart-row">
  <div class="chart-half">
    <h4>文档关键词 (TF-IDF)</h4>
    <div id="chart-keywords" class="chart-container"></div>
  </div>
  <div class="chart-half">
    <h4>事件类别分布</h4>
    <div id="chart-categories" class="chart-container"></div>
  </div>
</div>

<details>
  <summary>关键词共现网络 (交互式)</summary>
  <p class="caption">节点大小 = TF-IDF 权重, 连线 = 在同一段落中共现</p>
  <div id="keyword-network" class="chart-container" style="height:620px;"></div>
</details>

<h4>识别的人物名称</h4>
<div id="person-table-container">
  <table id="person-table" class="data-table">
    <thead><tr><th>#</th><th>姓名</th><th>提及次数</th><th>头衔</th><th>上下文</th></tr></thead>
    <tbody></tbody>
  </table>
</div>

<h4>自动洞察</h4>
<ul id="insights-list"></ul>

<hr>
<h4>数据处理管线</h4>
<div class="kpi-row" id="pipeline-kpis">
  <div class="kpi-card"><span class="kpi-value" id="pipe-chunks">0</span><span class="kpi-label">文档加载</span></div>
  <div class="kpi-card"><span class="kpi-value" id="pipe-keywords">0</span><span class="kpi-label">关键词分析</span></div>
  <div class="kpi-card"><span class="kpi-value" id="pipe-persons">0</span><span class="kpi-label">人物识别</span></div>
  <div class="kpi-card"><span class="kpi-value" id="pipe-graph">0</span><span class="kpi-label">图谱构建</span></div>
  <div class="kpi-card"><span class="kpi-value" id="pipe-timeline">0</span><span class="kpi-label">时间线</span></div>
  <div class="kpi-card"><span class="kpi-value" id="pipe-spatial">0</span><span class="kpi-label">空间提取</span></div>
</div>
