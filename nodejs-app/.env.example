LLM_API_KEY=
LLM_MAX_TOKEN_MULTIPLIER=100
LLM_MAX_TOKENS_CAP=1000000

# LM Studio 本地嵌入（OpenAI 兼容 /v1/embeddings）
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

PORT=3000
